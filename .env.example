# Neon: Settings -> Connection Details
# "Pooled connection" -> DATABASE_URL, "Direct connection" -> DIRECT_URL
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Faqat lokal migratsiyalar uchun (Neon'da ishlatilmaydi)
SHADOW_DATABASE_URL=""

# `openssl rand -base64 32` orqali generatsiya qiling
NEXTAUTH_SECRET=""
# Production domeningiz
NEXTAUTH_URL="https://your-app.vercel.app"

# @BotFather orqali yaratilgan bot tokeni
TELEGRAM_BOT_TOKEN=""

# Vercel Cron uchun maxfiy kalit (/api/telegram/cron himoyasi)
# `openssl rand -base64 32` orqali generatsiya qiling
CRON_SECRET=""

# Seed skripti uchun (ixtiyoriy, standart: admin / admin123)
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="admin123"
